# Local Docker database setup
POSTGRES_DB=codearena
POSTGRES_USER=codearena
POSTGRES_PASSWORD=codearena_dev_password

# Backend connects to docker compose db service
DB_HOST=db
DB_PORT=5432
DB_SSL_MODE=disable

# Redis Configuration
REDIS_HOST=cache
REDIS_PORT=6379
REDIS_PASSWORD=redis-secret

# Backend Configuration
BACKEND_PROFILES=dev
BACKEND_PORT=8080
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_EXPIRATION_MS=3600000
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:8080,https://localhost

# Frontend Configuration
FRONTEND_PORT=80

# Proxy Port Mappings
HOST_TO_PROXY_HTTP_PORT=8000
HOST_TO_PROXY_HTTPS_PORT=443
PROXY_INTERNAL_HTTP_PORT=80
PROXY_INTERNAL_HTTPS_PORT=443

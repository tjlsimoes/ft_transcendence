# PostgreSQL (docker-compose)
POSTGRES_DB=codearena
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# Spring datasource
DB_URL=jdbc:postgresql://localhost:5432/codearena
DB_USERNAME=postgres
DB_PASSWORD=changeme

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT — use a long random secret in production (min 64 chars recommended, e.g. openssl rand -hex 32)
JWT_SECRET=replace-with-a-64-char-random-hex-string-generated-by-openssl-rand-hex-32
JWT_EXPIRATION=86400000

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:4200

# JPA — set to "update" only in local dev; use "validate" or "none" elsewhere
JPA_DDL_AUTO=update

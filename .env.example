# Database Configuration
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# Database Network Configuration (Internal)
DB_HOST=
DB_PORT=5432
DB_SSL_MODE=

# Redis Configuration
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# Timezone (e.g. Europe/Lisbon, Europe/London, America/New_York)
TZ=

# Backend Configuration
BACKEND_PROFILES=
BACKEND_PORT=8080
JWT_SECRET=
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000
CORS_ALLOWED_ORIGINS=
JUDGE0_URL=

# Frontend Configuration
FRONTEND_PORT=80

# Proxy Port Mappings
HOST_TO_PROXY_HTTP_PORT=8000
HOST_TO_PROXY_HTTPS_PORT=443
PROXY_INTERNAL_HTTP_PORT=80
PROXY_INTERNAL_HTTPS_PORT=443

# Judge0 Infrastructure
JUDGE0_POSTGRES_DB=
JUDGE0_POSTGRES_USER=
JUDGE0_POSTGRES_PASSWORD=
JUDGE0_REDIS_PASSWORD=
JUDGE0_AUTH_TOKEN=

# Judge0 Execution Limits
JUDGE0_CPU_TIME_LIMIT=10
JUDGE0_MEMORY_LIMIT=128000
JUDGE0_MAX_PROCESSES_AND_OR_THREADS=60
JUDGE0_MAX_FILE_SIZE=4096
JUDGE0_ENABLE_NETWORK=false

# OAuth 2.0 Configuration (Optional – Bonus Module)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
FORTY_TWO_CLIENT_ID=
FORTY_TWO_CLIENT_SECRET=
OAUTH2_FRONTEND_CALLBACK_URL=https://localhost/oauth2/callback
